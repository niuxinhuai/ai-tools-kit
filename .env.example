# Provider: openai | openai-compatible | deepseek | qwen | doubao | moonshot | gemini | anthropic | ollama | mock
AI_PROVIDER=openai

# Common model setting. Each provider has a reasonable default if this is empty.
AI_MODEL=

# Generic OpenAI-compatible settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Provider-specific keys. Fill only what you use.
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider URLs.
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DOUBAO_BASE_URL=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
OLLAMA_BASE_URL=http://localhost:11434

# Server.
PORT=5177

# Optional API protection for public/self-hosted deployments.
# When set, POST /api/run, /api/run-stream, and /api/prompt require:
# Authorization: Bearer <token>
AI_TOOLS_API_TOKEN=
